{
  "name": "tokens-metric",
  "version": "0.3.4",
  "description": "Real-time token usage meter for Claude Code — statusline + Ink TUI.",
  "type": "module",
  "bin": {
    "tokens-metric": "dist/tui/index.js",
    "tokens-metric-statusline": "dist/statusline/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev:tui": "tsx src/tui/index.tsx",
    "dev:statusline": "tsx src/statusline/index.ts",
    "start": "node dist/tui/index.js",
    "statusline": "node dist/statusline/index.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "claude",
    "claude-code",
    "tokens",
    "usage",
    "statusline",
    "tui",
    "ink",
    "monitor"
  ],
  "author": "Annibal48",
  "license": "MIT",
  "homepage": "https://github.com/Annibal48/Tokens-Metric#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Annibal48/Tokens-Metric.git"
  },
  "bugs": {
    "url": "https://github.com/Annibal48/Tokens-Metric/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "ink": "^5.0.1",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "@types/react": "^18.3.3",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3"
  }
}
