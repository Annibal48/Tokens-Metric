{
  "name": "tokens-metric",
  "version": "0.1.0",
  "description": "Real-time token usage meter for Claude Code (statusline + TUI).",
  "type": "module",
  "bin": {
    "tokens-metric": "dist/tui/index.js",
    "tokens-metric-statusline": "dist/statusline/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev:tui": "tsx src/tui/index.tsx",
    "dev:statusline": "tsx src/statusline/index.ts",
    "start": "node dist/tui/index.js",
    "statusline": "node dist/statusline/index.js"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "ink": "^5.0.1",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "@types/react": "^18.3.3",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3"
  }
}
